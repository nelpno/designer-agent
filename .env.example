# OpenRouter (API única para LLMs + Geração de Imagem)
OPENROUTER_API_KEY=sk-or-v1-xxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# LLM Models (agentes pensantes)
LLM_MODEL=anthropic/claude-sonnet-4
VISION_MODEL=anthropic/claude-sonnet-4

# Image Models
IMAGE_MODEL_TEXT=google/gemini-3-pro-image-preview
IMAGE_MODEL_PHOTO=black-forest-labs/flux.2-pro
IMAGE_MODEL_FAST=google/gemini-3.1-flash-image-preview
IMAGE_MODEL_FLEX=black-forest-labs/flux.2-flex
IMAGE_MODEL_FONTS=sourceful/riverflow-v2-standard-preview

# Database
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@postgres:5432/DB_NAME
POSTGRES_USER=designer
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=designer_agent

# Redis
REDIS_URL=redis://redis:6379/0

# Security
API_SECRET_KEY=GENERATE_A_RANDOM_KEY_HERE
DEBUG=false

# Storage
STORAGE_PATH=/app/storage

# Pipeline
MAX_ITERATIONS=3
QUALITY_THRESHOLD=75

# n8n Webhook (notificações)
N8N_WEBHOOK_URL=

# App
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:5173
